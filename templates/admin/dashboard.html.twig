        <div class="kpi-label"><i class="fa fa-shopping-cart"></i> Commandes</div>
        <div class="kpi-arrow">→</div>
        <div class="kpi-sub">Historique & statuts</div>
    </a>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\UserCrudController') }}" class="kpi-card">
        <div class="kpi-label"><i class="fa fa-users"></i> Utilisateurs</div>
        <div class="kpi-arrow">→</div>
        <div class="kpi-sub">Comptes & rôles</div>
    </a>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\SaasServiceCrudController') }}" class="kpi-card">
        <div class="kpi-label"><i class="fa fa-box"></i> Services SaaS</div>
        <div class="kpi-arrow">→</div>
        <div class="kpi-sub">Catalogue & tarifs</div>
    </a>
