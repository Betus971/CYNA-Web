{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Tableau de bord{% endblock %}

{% block main %}
<style>
.kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
}
.kpi-card {
    background: var(--color-sidebar-dark, #1e293b);
    border: 1px solid var(--color-border, #334155);
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
    display: block;
    transition: border-color .15s;
}
.kpi-card:hover { border-color: #6366f1; }
.kpi-card.revenue { border-color: #10b981; }
.kpi-card.revenue:hover { border-color: #34d399; }
.kpi-label {
    color: var(--color-text-secondary, #94a3b8);
    font-size: .75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .06em;
    margin-bottom: .5rem;
}
.kpi-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-heading, #f8fafc);
    line-height: 1.2;
}
.kpi-value.green { color: #34d399; }
.kpi-arrow {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-heading, #f8fafc);
}
.kpi-sub {
    font-size: .8rem;
    color: var(--color-text-secondary, #94a3b8);
    margin-top: .35rem;
}
.section-title {
    font-size: .75rem;
    font-weight: 700;
    color: var(--color-text-secondary, #94a3b8);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin: 2rem 0 .875rem;
}
.quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: .625rem;
    margin-bottom: 2rem;
}
.quick-link {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    background: var(--color-sidebar-dark, #1e293b);
    border: 1px solid var(--color-border, #334155);
    border-radius: 8px;
    padding: .5rem .875rem;
    color: var(--color-text, #e2e8f0);
    text-decoration: none;
    font-size: .8125rem;
    transition: border-color .15s, color .15s;
}
.quick-link:hover { border-color: #6366f1; color: #818cf8; }
.recent-table { width: 100%; border-collapse: collapse; font-size: .85rem; }
.recent-table th {
    text-align: left;
    padding: .5rem .75rem;
    color: var(--color-text-secondary, #94a3b8);
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .06em;
    border-bottom: 1px solid var(--color-border, #334155);
}
.recent-table td {
    padding: .6rem .75rem;
    color: var(--color-text, #e2e8f0);
    border-bottom: 1px solid var(--color-border, #1e293b);
}
.recent-table tr:last-child td { border-bottom: none; }
.badge-paid {
    display: inline-block;
    background: #064e3b;
    color: #34d399;
    border-radius: 4px;
    padding: .1rem .5rem;
    font-size: .7rem;
    font-weight: 600;
    text-transform: uppercase;
}
</style>

{# ── KPI Revenus ── #}
<div class="kpi-grid">
    <div class="kpi-card revenue">
        <div class="kpi-label"><i class="fa fa-euro-sign"></i> CA total</div>
        <div class="kpi-value green">{{ revenue_total }} €</div>
        <div class="kpi-sub">Toutes commandes payées</div>
    </div>
    <div class="kpi-card revenue">
        <div class="kpi-label"><i class="fa fa-calendar-alt"></i> CA ce mois</div>
        <div class="kpi-value green">{{ revenue_month }} €</div>
        <div class="kpi-sub">{{ current_month }}</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label"><i class="fa fa-check-circle"></i> Commandes payées</div>
        <div class="kpi-value">{{ orders_paid }}</div>
        <div class="kpi-sub">Statuts paid / active / renewed</div>
    </div>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\OrderCrudController') }}" class="kpi-card">
        <div class="kpi-label"><i class="fa fa-shopping-cart"></i> Toutes commandes</div>
        <div class="kpi-arrow">→</div>
        <div class="kpi-sub">Historique & statuts</div>
    </a>
</div>

{# ── Derniers paiements ── #}
{% if recent_orders is not empty %}
<div class="section-title"><i class="fa fa-clock"></i> Derniers paiements reçus</div>
<div style="background: var(--color-sidebar-dark, #1e293b); border: 1px solid var(--color-border, #334155); border-radius: 10px; overflow: hidden; margin-bottom: 2rem;">
    <table class="recent-table">
        <thead>
            <tr>
                <th>Référence</th>
                <th>Client</th>
                <th>Montant</th>
                <th>Payée le</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            {% for order in recent_orders %}
            <tr>
                <td>
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\OrderCrudController').setAction('detail').setEntityId(order.id) }}"
                       style="color: #818cf8; text-decoration: none;">
                        {{ order.reference }}
                    </a>
                </td>
                <td>{{ order.user ? order.user : '—' }}</td>
                <td style="font-weight: 600;">{{ order.totalPrice }} €</td>
                <td>{{ order.paidAt ? order.paidAt|date('d/m/Y H:i') : '—' }}</td>
                <td><span class="badge-paid">{{ order.status.value }}</span></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{# ── Raccourcis ── #}
<div class="section-title">Accès rapides</div>
<div class="quick-links">
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\UserCrudController') }}" class="quick-link">
        <i class="fa fa-users"></i> Utilisateurs
    </a>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\SaasServiceCrudController') }}" class="quick-link">
        <i class="fa fa-box"></i> Services SaaS
    </a>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\CategoryCrudController') }}" class="quick-link">
        <i class="fa fa-folder"></i> Catégories
    </a>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\InvoiceCrudController') }}" class="quick-link">
        <i class="fa fa-file-invoice"></i> Factures
    </a>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\PromoCodeCrudController') }}" class="quick-link">
        <i class="fa fa-tag"></i> Codes promo
    </a>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ContactMessageCrudController') }}" class="quick-link">
        <i class="fa fa-envelope"></i> Messages contact
    </a>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ChatbotConversationCrudController') }}" class="quick-link">
        <i class="fa fa-robot"></i> Chatbot
    </a>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\CarouselSlideCrudController') }}" class="quick-link">
        <i class="fa fa-images"></i> Carrousel
    </a>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\HomepageTextCrudController') }}" class="quick-link">
        <i class="fa fa-align-left"></i> Textes dynamiques
    </a>
</div>
{% endblock %}
