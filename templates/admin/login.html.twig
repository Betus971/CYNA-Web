<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>CYNA Admin — Connexion</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #0f172a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .card {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 12px;
            padding: 2.5rem;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 25px 50px rgba(0,0,0,.5);
        }
        .logo {
            text-align: center;
            margin-bottom: 2rem;
        }
        .logo h1 { color: #f8fafc; font-size: 1.75rem; font-weight: 700; }
        .logo span { color: #6366f1; }
        .logo p { color: #94a3b8; font-size: .875rem; margin-top: .25rem; }
        .alert {
            background: #450a0a;
            border: 1px solid #dc2626;
            color: #fca5a5;
            border-radius: 8px;
            padding: .75rem 1rem;
            margin-bottom: 1.25rem;
            font-size: .875rem;
        }
        label { display: block; color: #94a3b8; font-size: .8125rem; font-weight: 500; margin-bottom: .375rem; }
        input[type=email], input[type=password] {
            width: 100%;
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 8px;
            color: #f8fafc;
            padding: .625rem .875rem;
            font-size: .9375rem;
            margin-bottom: 1.25rem;
            transition: border-color .15s;
        }
        input:focus { outline: none; border-color: #6366f1; }
        button {
            width: 100%;
            background: #6366f1;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: .75rem;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s;
        }
        button:hover { background: #4f46e5; }
    </style>
</head>
<body>
<div class="card">
    <div class="logo">
        <h1>CY<span>NA</span></h1>
        <p>Backoffice Administration</p>
    </div>

    {% if error %}
        <div class="alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form method="post">
        <label for="email">Adresse email</label>
        <input type="email" id="email" name="email" value="{{ last_username }}" autocomplete="email" autofocus required>

        <label for="password">Mot de passe</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit">Se connecter</button>
    </form>
</div>
</body>
</html>
