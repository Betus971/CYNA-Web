{% set firstname = user.firstname|default('') %}
<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>Nouvelle connexion CYNA</title>
</head>
<body style="margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#172033;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f4f7fb;padding:32px 16px;">
        <tr>
            <td align="center">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:600px;background:#ffffff;border-radius:8px;overflow:hidden;border:1px solid #e4eaf2;">
                    <tr>
                        <td style="background:#0f172a;color:#ffffff;padding:24px 28px;">
                            <div style="font-size:22px;font-weight:700;">CYNA</div>
                            <div style="font-size:14px;margin-top:6px;color:#cbd5e1;">Alerte de securite</div>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:32px 28px;">
                            <h1 style="margin:0 0 16px;font-size:24px;line-height:1.3;color:#0f172a;">Nouvelle connexion detectee</h1>
                            <p style="margin:0 0 20px;font-size:16px;line-height:1.6;">
                                Bonjour {{ firstname ? firstname : 'CYNA' }}, une connexion a votre compte vient d'etre validee.
                            </p>
                            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;font-size:15px;">
                                <tr><td style="padding:10px 0;color:#64748b;border-bottom:1px solid #e4eaf2;">Adresse IP</td><td style="padding:10px 0;border-bottom:1px solid #e4eaf2;text-align:right;">{{ login.ip }}</td></tr>
                                <tr><td style="padding:10px 0;color:#64748b;border-bottom:1px solid #e4eaf2;">Systeme</td><td style="padding:10px 0;border-bottom:1px solid #e4eaf2;text-align:right;">{{ login.platform }}</td></tr>
                                <tr><td style="padding:10px 0;color:#64748b;border-bottom:1px solid #e4eaf2;">Navigateur</td><td style="padding:10px 0;border-bottom:1px solid #e4eaf2;text-align:right;">{{ login.browser }}</td></tr>
                                <tr><td style="padding:10px 0;color:#64748b;">Date</td><td style="padding:10px 0;text-align:right;">{{ login.occurred_at|date('d/m/Y H:i') }}</td></tr>
                            </table>
                            <p style="margin:24px 0 0;font-size:14px;line-height:1.6;color:#475569;word-break:break-word;">
                                Agent complet : {{ login.user_agent }}
                            </p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:20px 28px;background:#f8fafc;border-top:1px solid #e4eaf2;font-size:13px;line-height:1.5;color:#64748b;">
                            Si cette connexion ne vient pas de vous, changez votre mot de passe immediatement.
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
