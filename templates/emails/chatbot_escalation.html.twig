<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>Escalade Support Chatbot - CYNA</title>
</head>
<body style="margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#172033;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f4f7fb;padding:32px 16px;">
        <tr>
            <td align="center">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:600px;background:#ffffff;border-radius:8px;overflow:hidden;border:1px solid #e4eaf2;">
                    <tr>
                        <td style="background:#0f172a;color:#ffffff;padding:24px 28px;">
                            <div style="font-size:22px;font-weight:700;">CYNA</div>
                            <div style="font-size:14px;margin-top:6px;color:#cbd5e1;">Alerte Escalade Chatbot IA</div>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:32px 28px;">
                            <h1 style="margin:0 0 16px;font-size:24px;line-height:1.3;color:#0f172a;">Demande de transfert à un agent</h1>
                            <p style="margin:0 0 16px;font-size:16px;line-height:1.6;">
                                Bonjour,
                            </p>
                            <p style="margin:0 0 24px;font-size:16px;line-height:1.6;">
                                Une conversation avec le chatbot a été escaladée vers le support humain. Voici les détails de l'utilisateur :
                            </p>
                            
                            <table role="presentation" width="100%" cellspacing="0" cellpadding="8" style="background:#f8fafc;border:1px solid #e4eaf2;border-radius:8px;margin-bottom:24px;">
                                <tr>
                                    <td width="30%" style="font-weight:700;color:#475569;">Nom :</td>
                                    <td style="color:#0f172a;">{{ conversation.fullName|default('Visiteur anonyme') }}</td>
                                </tr>
                                <tr>
                                    <td style="font-weight:700;color:#475569;">Email :</td>
                                    <td style="color:#0f172a;">
                                        {% if conversation.email %}
                                            <a href="mailto:{{ conversation.email }}" style="color:#1d8dff;text-decoration:none;">{{ conversation.email }}</a>
                                        {% else %}
                                            Non fourni
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <td style="font-weight:700;color:#475569;">Sujet :</td>
                                    <td style="color:#0f172a;">{{ conversation.subject|default('Demande chatbot') }}</td>
                                </tr>
                                <tr>
                                    <td style="font-weight:700;color:#475569;">Date d'escalade :</td>
                                    <td style="color:#0f172a;">{{ sent_at|date('d/MM/yyyy H:i') }}</td>
                                </tr>
                            </table>

                            <h2 style="margin:24px 0 12px;font-size:18px;color:#0f172a;border-bottom:2px solid #f1f5f9;padding-bottom:6px;">Historique des échanges</h2>
                            <div style="background:#fafafa;border:1px solid #e2e8f0;border-radius:8px;padding:16px;font-family:monospace;white-space:pre-wrap;font-size:13px;line-height:1.5;color:#334155;max-height:350px;overflow-y:auto;margin-bottom:24px;">{{ transcript|escape }}</div>

                            <p style="margin:0;font-size:14px;line-height:1.6;color:#64748b;">
                                Vous pouvez retrouver et traiter cette conversation directement sur votre <a href="http://localhost:8000/admin" style="color:#1d8dff;text-decoration:underline;">tableau de bord EasyAdmin</a>.
                            </p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:20px 28px;background:#f8fafc;border-top:1px solid #e4eaf2;font-size:13px;line-height:1.5;color:#64748b;text-align:center;">
                            CYNA-IT Security Platform — Service Support
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
